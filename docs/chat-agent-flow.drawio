        <!-- ==================== CONNECTOR: REACT → MEMORY LAYER ==================== -->
        <mxCell id="e-react-mem1" value="query" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;dashPattern=5 3;fontStyle=2;fontColor=#82b366;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" source="memory-check" target="mem-smart" parent="1">
          <mxGeometry relative="1" as="geometry">
