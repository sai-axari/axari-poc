        <!-- ==================== DECISION FLOW LEGEND ==================== -->
        <mxCell id="legend-group" value="&lt;b&gt;TOOL RESOLUTION PRIORITY&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1380" y="960" width="350" height="210" as="geometry"/>
        </mxCell>
        <mxCell id="leg1" value="&lt;b&gt;1. Smart Summary (Memory Layer)&lt;/b&gt;&lt;br&gt;Pre-polled + LLM-summarized data&lt;br&gt;Fastest — no API call, no LLM processing&lt;br&gt;&lt;i&gt;Freshness: 5-15 min depending on source&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="legend-group">
          <mxGeometry x="15" y="35" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg2" value="&lt;b&gt;2. Processed Tool Data (DB)&lt;/b&gt;&lt;br&gt;Raw API results stored from previous calls&lt;br&gt;Fast — DB read, possibly slightly stale&lt;br&gt;&lt;i&gt;Freshness: from last tool call in any session&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="legend-group">
          <mxGeometry x="15" y="93" width="320" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg3" value="&lt;b&gt;3. Live Tool Call (API)&lt;/b&gt;&lt;br&gt;Direct call to integration API&lt;br&gt;Slowest — real-time, freshest data&lt;br&gt;&lt;i&gt;Used when no cached/summarized data exists&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="legend-group">
          <mxGeometry x="15" y="150" width="320" height="50" as="geometry"/>
        </mxCell>

        <!-- ==================== EXAMPLE FLOW ANNOTATION ==================== -->
        <mxCell id="example-group" value="&lt;b&gt;EXAMPLE: &quot;What&#39;s my security posture and urgent Jira tickets?&quot;&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="1170" width="1200" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="ex-iter1" value="&lt;b&gt;Iteration 1&lt;/b&gt;&lt;br&gt;LLM decides: need CrowdStrike&lt;br&gt;alerts + Jira tickets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="example-group">
          <mxGeometry x="20" y="40" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ex-cs-check" value="&lt;b&gt;CrowdStrike alerts&lt;/b&gt;&lt;br&gt;→ Memory Layer: ✓ FRESH&lt;br&gt;(polled 8 min ago)&lt;br&gt;&lt;b&gt;Uses smart summary&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="example-group">
          <mxGeometry x="220" y="35" width="180" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ex-jira-check" value="&lt;b&gt;Jira urgent tickets&lt;/b&gt;&lt;br&gt;→ Memory Layer: ✗ STALE&lt;br&gt;→ DB processed: ✗ NONE&lt;br&gt;&lt;b&gt;Makes live API call&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="example-group">
          <mxGeometry x="430" y="35" width="180" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ex-store" value="&lt;b&gt;Jira result stored&lt;/b&gt;&lt;br&gt;→ processed_tool_data&lt;br&gt;→ smart_summaries&lt;br&gt;(for next request)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="example-group">
          <mxGeometry x="640" y="35" width="160" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ex-iter2" value="&lt;b&gt;Iteration 2&lt;/b&gt;&lt;br&gt;LLM has both results&lt;br&gt;No more tools needed&lt;br&gt;→ Generates final response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="example-group">
          <mxGeometry x="830" y="35" width="175" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="ex-resp" value="&lt;b&gt;Response:&lt;/b&gt; &quot;Your security posture shows 3 critical CrowdStrike alerts...&lt;br&gt;and 2 urgent Jira tickets: PROJ-123 (auth bypass) and PROJ-456 (cert expiry)...&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#333333;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="example-group">
          <mxGeometry x="20" y="125" width="980" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="ex-savings" value="&lt;b&gt;Savings:&lt;/b&gt; CrowdStrike call avoided (used 8-min-old summary) — saved ~2s latency + API quota.&lt;br&gt;Jira called live because no fresh data existed — result now cached for subsequent requests." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;fontStyle=2;" vertex="1" parent="example-group">
          <mxGeometry x="20" y="175" width="980" height="35" as="geometry"/>
        </mxCell>

        <!-- Example arrows -->
        <mxCell id="exe1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="ex-iter1" target="ex-cs-check" parent="example-group">
