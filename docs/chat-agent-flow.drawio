        <mxCell id="e-bg-mem" value="writes summaries" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;dashed=1;dashPattern=12 4;fontStyle=2;fontColor=#82b366;" edge="1" source="bg-smart-store" target="mem-smart" parent="1">
