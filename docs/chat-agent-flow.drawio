<mxfile host="app.diagrams.net" agent="Claude" version="26.0">
  <diagram name="Chat Agent Flow with Memory Layer" id="chat-agent-flow">
    <mxGraphModel dx="2800" dy="3400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3300" pageHeight="5000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== TITLE ==================== -->
        <mxCell id="title" value="&lt;b&gt;Axari Chat Agent Flow — Memory-First Architecture&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=22;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="700" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Agent checks pre-polled smart summaries in the Memory Layer before making live tool calls" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="370" y="55" width="660" height="25" as="geometry"/>
        </mxCell>

        <!-- ==================== BACKGROUND POLLING (TOP LEFT) ==================== -->
        <mxCell id="bg-group" value="&lt;b&gt;BACKGROUND POLLING (Async / Scheduled)&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;fontSize=13;fontStyle=1;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="-350" y="100" width="380" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="bg-scheduler" value="&lt;b&gt;Scheduler / Cron&lt;/b&gt;&lt;br&gt;Periodic polling triggers&lt;br&gt;(every 5-15 min per integration)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;size=15;" vertex="1" parent="bg-group">
          <mxGeometry x="65" y="50" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bg-poll-jira" value="&lt;b&gt;Poll Jira&lt;/b&gt;&lt;br&gt;Tickets, comments,&lt;br&gt;sprint data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="bg-group">
          <mxGeometry x="20" y="160" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bg-poll-email" value="&lt;b&gt;Poll Email&lt;/b&gt;&lt;br&gt;Inbox, threads,&lt;br&gt;action items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="bg-group">
          <mxGeometry x="200" y="160" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bg-poll-cal" value="&lt;b&gt;Poll Calendar&lt;/b&gt;&lt;br&gt;Events, attendees,&lt;br&gt;conflicts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="bg-group">
          <mxGeometry x="20" y="240" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bg-poll-sec" value="&lt;b&gt;Poll Security&lt;/b&gt;&lt;br&gt;CrowdStrike, Defender,&lt;br&gt;Qualys, Vanta" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="bg-group">
          <mxGeometry x="200" y="240" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="bg-raw-store" value="&lt;b&gt;Raw Data Store&lt;/b&gt;&lt;br&gt;(PostgreSQL)&lt;br&gt;integration_snapshots table" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="bg-group">
          <mxGeometry x="105" y="340" width="170" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bg-summarizer" value="&lt;b&gt;Summarization Pipeline&lt;/b&gt;&lt;br&gt;LLM processes raw data&lt;br&gt;into smart summaries&lt;br&gt;(structured + narrative)" style="shape=process;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#d5e8d4;strokeColor=#82b366;size=8;" vertex="1" parent="bg-group">
          <mxGeometry x="65" y="450" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="bg-smart-store" value="&lt;b&gt;Smart Summaries&lt;/b&gt;&lt;br&gt;→ Memory Layer DB&lt;br&gt;(indexed by tool, tenant,&lt;br&gt;timestamp, freshness)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="bg-group">
          <mxGeometry x="105" y="550" width="170" height="70" as="geometry" id="bg-smart-store-geo"/>
        </mxCell>

        <!-- Background polling arrows -->
        <mxCell id="bg-e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="bg-scheduler" target="bg-poll-jira" parent="bg-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="bg-e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;" edge="1" source="bg-scheduler" target="bg-poll-email" parent="bg-group">
          <mxGeometry relative="1" as="geometry"/>
