        <mxCell id="leg8" value="Database" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="legend">
          <mxGeometry x="155" y="105" width="80" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="leg9" value="&lt;font size=&quot;1&quot;&gt;Solid = data flow&lt;br&gt;Dashed = optional/async&lt;/font&gt;" style="text;html=1;align=left;" vertex="1" parent="legend">
