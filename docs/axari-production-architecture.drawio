<mxfile host="app.diagrams.net" agent="Claude" version="26.0">
  <diagram name="End-to-End Request Flow" id="request-flow">
    <mxGraphModel dx="2500" dy="2000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="3300" pageHeight="5000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ==================== TITLE ==================== -->
        <mxCell id="title" value="&lt;b&gt;Axari Production Architecture — End-to-End Request Flow&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=20;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="600" height="40" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 1: FRONTEND ==================== -->
        <mxCell id="frontend-group" value="&lt;b&gt;FRONTEND&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=14;fontStyle=1;horizontal=1;swimlaneLine=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="1200" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="user-input" value="&lt;b&gt;User Types Message&lt;/b&gt;&lt;br&gt;&lt;i&gt;&quot;What&#39;s my security posture&lt;br&gt;and any urgent Jira tickets?&quot;&lt;/i&gt;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="frontend-group">
          <mxGeometry x="30" y="50" width="250" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="chat-ui" value="&lt;b&gt;Chat UI&lt;/b&gt;&lt;br&gt;Messages + Thinking&lt;br&gt;Steps + Trajectory&lt;br&gt;+ Feedback (thumbs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="frontend-group">
          <mxGeometry x="340" y="50" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="dashboard-ui" value="&lt;b&gt;Dashboard&lt;/b&gt;&lt;br&gt;Priorities&lt;br&gt;Commitments&lt;br&gt;Meeting Prep" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="frontend-group">
          <mxGeometry x="540" y="50" width="140" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="detail-panel" value="&lt;b&gt;Detail Panel&lt;/b&gt;&lt;br&gt;Data | Reminders | Notes&lt;br&gt;(tool results, commitments,&lt;br&gt;user notes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="frontend-group">
          <mxGeometry x="720" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="sse-label" value="&lt;b&gt;SSE Stream&lt;/b&gt;&lt;br&gt;(real-time events)" style="text;html=1;align=center;verticalAlign=middle;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="frontend-group">
          <mxGeometry x="960" y="60" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="e-user-chat" edge="1" source="user-input" target="chat-ui" parent="frontend-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 2: API ==================== -->
        <mxCell id="api-group" value="&lt;b&gt;API LAYER (FastAPI :8100)&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="290" width="1200" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="chat-stream" value="&lt;b&gt;POST /v1/chat/stream&lt;/b&gt;&lt;br&gt;Primary SSE endpoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="api-group">
          <mxGeometry x="30" y="50" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="create-instances" value="&lt;b&gt;Create Instances&lt;/b&gt;&lt;br&gt;LLMClient&lt;br&gt;EventEmitter(conv_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="api-group">
          <mxGeometry x="270" y="50" width="170" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="other-endpoints" value="&lt;b&gt;Other Endpoints&lt;/b&gt;&lt;br&gt;/v1/dashboard&lt;br&gt;/v1/responsibilities&lt;br&gt;/v1/feedback&lt;br&gt;/v1/behavior" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;" vertex="1" parent="api-group">
          <mxGeometry x="960" y="40" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e-api1" edge="1" source="chat-stream" target="create-instances" parent="api-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connect frontend to API -->
        <mxCell id="e-front-api" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="user-input" target="chat-stream" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 3: MEMORY ASSEMBLY ==================== -->
        <mxCell id="memory-group" value="&lt;b&gt;MEMORY ASSEMBLY&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="480" width="1200" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="load-history" value="&lt;b&gt;Load Conversation&lt;br&gt;History&lt;/b&gt;&lt;br&gt;DB: conversation_messages&lt;br&gt;(last 20 messages)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="memory-group">
          <mxGeometry x="30" y="50" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="load-summary" value="&lt;b&gt;Load Prior Summary&lt;/b&gt;&lt;br&gt;DB: memory_summaries&lt;br&gt;(compacted older turns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="memory-group">
          <mxGeometry x="30" y="150" width="180" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="load-prefs" value="&lt;b&gt;Load User Preferences&lt;/b&gt;&lt;br&gt;DB: user_preferences&lt;br&gt;(response style, top tools,&lt;br&gt;workflow patterns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="memory-group">
          <mxGeometry x="260" y="50" width="190" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="load-behavior" value="&lt;b&gt;Load Behavior Profile&lt;/b&gt;&lt;br&gt;DB: user_behavior_events&lt;br&gt;(peak hours, top actions,&lt;br&gt;nudges)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="memory-group">
          <mxGeometry x="260" y="150" width="190" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="context-assembler" value="&lt;b&gt;Context Assembler&lt;/b&gt;&lt;br&gt;1. Summary + Recent msgs&lt;br&gt;2. Token count (API)&lt;br&gt;3. Budget check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="memory-group">
          <mxGeometry x="520" y="50" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="compact-decision" value="Over&lt;br&gt;budget?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="memory-group">
          <mxGeometry x="560" y="155" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="compaction" value="&lt;b&gt;Compaction&lt;/b&gt;&lt;br&gt;Summarize older msgs&lt;br&gt;via Claude Haiku&lt;br&gt;Store in memory_summaries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="memory-group">
          <mxGeometry x="720" y="145" width="190" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="assembled-context" value="&lt;b&gt;Assembled Context&lt;/b&gt;&lt;br&gt;[summary] + [recent msgs]&lt;br&gt;+ [user message]&lt;br&gt;Within token budget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="memory-group">
          <mxGeometry x="970" y="70" width="190" height="80" as="geometry"/>
        </mxCell>
        <!-- Memory edges -->
        <mxCell id="e-m1" edge="1" source="load-history" target="context-assembler" parent="memory-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-m2" edge="1" source="load-prefs" target="context-assembler" parent="memory-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-m3" edge="1" source="context-assembler" target="compact-decision" parent="memory-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-m4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="compact-decision" target="compaction" parent="memory-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-m5" value="No" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="compact-decision" target="assembled-context" parent="memory-group">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="230"/>
              <mxPoint x="940" y="230"/>
              <mxPoint x="940" y="110"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-m6" edge="1" source="compaction" target="assembled-context" parent="memory-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connect API to Memory -->
        <mxCell id="e-api-mem" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#9673a6;" edge="1" source="create-instances" target="load-history" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 4: ORCHESTRATOR SETUP ==================== -->
        <mxCell id="orch-group" value="&lt;b&gt;ORCHESTRATOR SETUP&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="760" width="1200" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="tool-discovery" value="&lt;b&gt;Tool Discovery&lt;/b&gt;&lt;br&gt;DB: integrations +&lt;br&gt;org_integrations&lt;br&gt;WHERE tenant = :tid&lt;br&gt;&lt;br&gt;&lt;i&gt;Result: [jira, outlook,&lt;br&gt;crowdstrike, teams...]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="orch-group">
          <mxGeometry x="30" y="50" width="170" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="tool-registry" value="&lt;b&gt;Tool Registry Filter&lt;/b&gt;&lt;br&gt;Match integration keys&lt;br&gt;to registered tools&lt;br&gt;&lt;br&gt;25 integration tools&lt;br&gt;+ 5 meta-tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="orch-group">
          <mxGeometry x="240" y="50" width="170" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="worker-context" value="&lt;b&gt;Fetch Worker Context&lt;/b&gt;&lt;br&gt;DB: ai_workers +&lt;br&gt;playbooks + contexts +&lt;br&gt;today&#39;s executions&lt;br&gt;&lt;br&gt;&lt;i&gt;Markdown string for&lt;br&gt;prompt injection&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="orch-group">
          <mxGeometry x="450" y="50" width="180" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="build-prompt" value="&lt;b&gt;Build System Prompt&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font size=&quot;1&quot;&gt;&amp;lt;role&amp;gt; Atlas persona&lt;br&gt;&amp;lt;persona&amp;gt; Eve + Janice&lt;br&gt;&amp;lt;user_preferences&amp;gt;&lt;br&gt;&amp;lt;worker_knowledge&amp;gt;&lt;br&gt;&amp;lt;available_tools&amp;gt;&lt;br&gt;&amp;lt;execution_instructions&amp;gt;&lt;br&gt;&amp;lt;context&amp;gt; tenant, user, time&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="orch-group">
          <mxGeometry x="680" y="40" width="190" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="meta-tools" value="&lt;b&gt;Meta-Tools&lt;/b&gt;&lt;br&gt;analyze&lt;br&gt;delegate_subtask&lt;br&gt;take_notes&lt;br&gt;add_reminder&lt;br&gt;trigger_responsibility" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="orch-group">
          <mxGeometry x="920" y="50" width="170" height="120" as="geometry"/>
        </mxCell>
        <!-- Orch edges -->
        <mxCell id="e-o1" edge="1" source="tool-discovery" target="tool-registry" parent="orch-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-o2" edge="1" source="tool-registry" target="build-prompt" parent="orch-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-o3" edge="1" source="worker-context" target="build-prompt" parent="orch-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-o4" edge="1" source="meta-tools" target="build-prompt" parent="orch-group" style="dashed=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connect Memory to Orchestrator -->
        <mxCell id="e-mem-orch" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#d6b656;" edge="1" source="assembled-context" target="build-prompt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 5: REACT LOOP ==================== -->
        <mxCell id="react-group" value="&lt;b&gt;REACT LOOP (Core Agent Engine)&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="1010" width="1200" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="llm-call" value="&lt;b&gt;LLM Streaming Call&lt;/b&gt;&lt;br&gt;Claude Sonnet 4&lt;br&gt;Extended Thinking (4K)&lt;br&gt;System + Messages + Tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="react-group">
          <mxGeometry x="30" y="60" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="stream-thinking" value="&lt;b&gt;Stream Thinking&lt;/b&gt;&lt;br&gt;thinking_delta&lt;br&gt;&#8594; SSE: thinking event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="react-group">
          <mxGeometry x="30" y="170" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="stream-text" value="&lt;b&gt;Stream Text&lt;/b&gt;&lt;br&gt;text_delta&lt;br&gt;&#8594; SSE: response_chunk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="react-group">
          <mxGeometry x="30" y="250" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="parse-response" value="&lt;b&gt;Parse Response&lt;/b&gt;&lt;br&gt;Separate content blocks:&lt;br&gt;[thinking] [text] [tool_use]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="react-group">
          <mxGeometry x="290" y="60" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="tool-check" value="Tool calls&lt;br&gt;found?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="react-group">
          <mxGeometry x="340" y="190" width="110" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="final-response" value="&lt;b&gt;DONE&lt;/b&gt;&lt;br&gt;Return final_text&lt;br&gt;trajectory&lt;br&gt;token_usage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;strokeWidth=2;" vertex="1" parent="react-group">
          <mxGeometry x="290" y="310" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="response-clear" value="&lt;b&gt;Clear Streamed Text&lt;/b&gt;&lt;br&gt;SSE: response_clear&lt;br&gt;(text was intermediate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="react-group">
          <mxGeometry x="530" y="60" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="parallel-exec" value="&lt;b&gt;Parallel Tool Execution&lt;/b&gt;&lt;br&gt;asyncio.gather(*tool_calls)&lt;br&gt;&lt;hr&gt;For each tool:&lt;br&gt;1. Check cache (hit/miss)&lt;br&gt;2. Execute async function&lt;br&gt;3. Cache result (5min TTL)&lt;br&gt;4. Full result &#8594; SSE: tool_result&lt;br&gt;5. Truncated &#8594; LLM context&lt;br&gt;6. Record in trajectory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=left;spacingLeft=10;" vertex="1" parent="react-group">
          <mxGeometry x="550" y="140" width="230" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="append-results" value="&lt;b&gt;Append to Messages&lt;/b&gt;&lt;br&gt;+ assistant (tool_use blocks)&lt;br&gt;+ user (tool_result blocks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="react-group">
          <mxGeometry x="840" y="190" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="loop-back" value="&lt;b&gt;Next Iteration&lt;/b&gt;&lt;br&gt;(max 15)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="react-group">
          <mxGeometry x="880" y="60" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- React edges -->
        <mxCell id="e-r1" edge="1" source="llm-call" target="parse-response" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r1b" edge="1" source="llm-call" target="stream-thinking" parent="react-group" style="dashed=1;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r1c" edge="1" source="llm-call" target="stream-text" parent="react-group" style="dashed=1;strokeColor=#9673a6;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r2" edge="1" source="parse-response" target="tool-check" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r3" value="No" edge="1" source="tool-check" target="final-response" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r4" value="Yes" edge="1" source="tool-check" target="response-clear" parent="react-group" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="500" y="230"/>
              <mxPoint x="500" y="90"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-r5" edge="1" source="response-clear" target="parallel-exec" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r6" edge="1" source="parallel-exec" target="append-results" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r7" edge="1" source="append-results" target="loop-back" parent="react-group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-r8" style="edgeStyle=orthogonalEdgeStyle;curved=1;strokeColor=#b85450;strokeWidth=2;" edge="1" source="loop-back" target="llm-call" parent="react-group">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1060" y="85"/>
              <mxPoint x="1060" y="40"/>
              <mxPoint x="130" y="40"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Connect Orchestrator to React -->
        <mxCell id="e-orch-react" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#b85450;" edge="1" source="build-prompt" target="llm-call" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ==================== LAYER 6: MULTI-AGENT / WORKERS ==================== -->
        <mxCell id="worker-group" value="&lt;b&gt;SPECIALIZED WORKERS (via delegate_subtask)&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="1440" width="1200" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="security-worker" value="&lt;b&gt;SecurityWorker&lt;/b&gt;&lt;br&gt;(tool_runner)&lt;br&gt;&lt;hr&gt;CrowdStrike&lt;br&gt;Defender&lt;br&gt;Rapid7 / Qualys&lt;br&gt;&lt;hr&gt;&lt;i&gt;Max 8 iterations&lt;br&gt;No streaming&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="worker-group">
          <mxGeometry x="80" y="50" width="160" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="comms-worker" value="&lt;b&gt;CommsWorker&lt;/b&gt;&lt;br&gt;(tool_runner)&lt;br&gt;&lt;hr&gt;Outlook / Gmail&lt;br&gt;MS Calendar / Google Cal&lt;br&gt;Teams / Slack&lt;br&gt;&lt;hr&gt;&lt;i&gt;Max 8 iterations&lt;br&gt;No streaming&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="worker-group">
          <mxGeometry x="310" y="50" width="180" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="project-worker" value="&lt;b&gt;ProjectWorker&lt;/b&gt;&lt;br&gt;(tool_runner)&lt;br&gt;&lt;hr&gt;Jira / GitHub&lt;br&gt;Vanta / Notion&lt;br&gt;SharePoint / Drive&lt;br&gt;&lt;hr&gt;&lt;i&gt;Max 8 iterations&lt;br&gt;No streaming&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="worker-group">
