  <diagram name="Multi-Agent Delegation Flow" id="multi-agent">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="2000" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="ma-title" value="&lt;b&gt;Multi-Agent Delegation Flow&lt;/b&gt;&lt;br&gt;&lt;i&gt;Example: &quot;Investigate CrowdStrike alert CS-789, find related Jira tickets, check PRs&quot;&lt;/i&gt;" style="text;html=1;align=center;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="50" as="geometry"/>
        </mxCell>

        <!-- User -->
        <mxCell id="ma-user" value="&lt;b&gt;User Message&lt;/b&gt;&lt;br&gt;&quot;Investigate CrowdStrike alert CS-789,&lt;br&gt;find related Jira tickets, check PRs&quot;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="90" width="300" height="70" as="geometry"/>
        </mxCell>

        <!-- Orchestrator Iteration 1 -->
        <mxCell id="ma-orch1" value="&lt;b&gt;Orchestrator (Atlas) — Iteration 1&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="190" width="700" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="ma-think1" value="&lt;b&gt;Extended Thinking&lt;/b&gt;&lt;br&gt;&quot;This requires iterative multi-step work.&lt;br&gt;Need to: 1) fetch alert details 2) extract&lt;br&gt;hosts 3) search Jira 4) check PRs.&lt;br&gt;This is a delegate_subtask case.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="ma-orch1">
          <mxGeometry x="20" y="45" width="290" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="ma-delegate" value="&lt;b&gt;Tool Calls (parallel)&lt;/b&gt;&lt;br&gt;1. delegate_subtask &#8594; SecurityWorker&lt;br&gt;2. delegate_subtask &#8594; ProjectWorker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;" vertex="1" parent="ma-orch1">
          <mxGeometry x="380" y="55" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e-ma1" edge="1" source="ma-think1" target="ma-delegate" parent="ma-orch1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e-ma-user" edge="1" source="ma-user" target="ma-think1" parent="1" style="strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Security Worker -->
        <mxCell id="ma-sec" value="&lt;b&gt;SecurityWorker&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="400" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="ma-sec-prompt" value="&lt;b&gt;System:&lt;/b&gt; &quot;You are a security analyst.&lt;br&gt;Investigate thoroughly.&quot;&lt;br&gt;&lt;b&gt;Tools:&lt;/b&gt; CrowdStrike (3 tools)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="ma-sec">
          <mxGeometry x="15" y="35" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-sec-i1" value="&lt;b&gt;Iter 1:&lt;/b&gt; fetch_incident_detail(CS-789)&lt;br&gt;&#8594; Alert on host prod-web-03&lt;br&gt;   Lateral movement detected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-sec">
          <mxGeometry x="15" y="100" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-sec-i2" value="&lt;b&gt;Iter 2:&lt;/b&gt; get_host_details(prod-web-03)&lt;br&gt;&#8594; IP: 10.0.1.42, OS: Ubuntu 22.04&lt;br&gt;   Last seen: 2h ago, Status: contained" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-sec">
          <mxGeometry x="15" y="165" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-sec-i3" value="&lt;b&gt;Iter 3:&lt;/b&gt; get_alert_details(alert-456)&lt;br&gt;&#8594; Technique: T1021 (RDP), Severity: Critical&lt;br&gt;   Related IOCs: 3 suspicious IPs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-sec">
          <mxGeometry x="15" y="230" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-sec-result" value="&lt;b&gt;Returns:&lt;/b&gt; Structured security findings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=10;" vertex="1" parent="ma-sec">
          <mxGeometry x="80" y="300" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- Project Worker -->
        <mxCell id="ma-proj" value="&lt;b&gt;ProjectWorker&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="420" width="400" height="340" as="geometry"/>
        </mxCell>
        <mxCell id="ma-proj-prompt" value="&lt;b&gt;System:&lt;/b&gt; &quot;You are a project tracker.&lt;br&gt;Cross-reference data.&quot;&lt;br&gt;&lt;b&gt;Tools:&lt;/b&gt; Jira (3) + GitHub (5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="ma-proj">
          <mxGeometry x="15" y="35" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-proj-i1" value="&lt;b&gt;Iter 1:&lt;/b&gt; search_jira_issues(&quot;prod-web-03&quot;)&lt;br&gt;&#8594; SEC-1234 (stalled 4 days, P1)&lt;br&gt;   SEC-1201 (resolved last week)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-proj">
          <mxGeometry x="15" y="100" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-proj-i2" value="&lt;b&gt;Iter 2:&lt;/b&gt; list_pull_requests(repo, state=merged)&lt;br&gt;&#8594; PR #456 merged (linked to SEC-1201)&lt;br&gt;   But doesn&#39;t address lateral movement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-proj">
          <mxGeometry x="15" y="165" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-proj-i3" value="&lt;b&gt;Iter 3:&lt;/b&gt; get_pull_request(#456)&lt;br&gt;&#8594; Changes: firewall rules only&lt;br&gt;   Missing: RDP hardening, host isolation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=5;" vertex="1" parent="ma-proj">
          <mxGeometry x="15" y="230" width="370" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ma-proj-result" value="&lt;b&gt;Returns:&lt;/b&gt; Jira + GitHub findings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=10;" vertex="1" parent="ma-proj">
          <mxGeometry x="80" y="300" width="240" height="30" as="geometry"/>
        </mxCell>

        <!-- Connect Orch to Workers -->
        <mxCell id="e-ma-sec" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="ma-delegate" target="ma-sec-prompt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-ma-proj" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" source="ma-delegate" target="ma-proj-prompt" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Orchestrator Iteration 2 -->
        <mxCell id="ma-orch2" value="&lt;b&gt;Orchestrator (Atlas) — Iteration 2 (Synthesis)&lt;/b&gt;" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="800" width="700" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="ma-think2" value="&lt;b&gt;Extended Thinking&lt;/b&gt;&lt;br&gt;&quot;Security found lateral movement on&lt;br&gt;prod-web-03. Jira has SEC-1234 (stalled&lt;br&gt;4 days). PR #456 merged but didn&#39;t fix&lt;br&gt;root cause. Need to escalate + new ticket.&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="ma-orch2">
          <mxGeometry x="20" y="45" width="290" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="ma-final" value="&lt;b&gt;Final Response (Atlas persona)&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font size=&quot;2&quot;&gt;&quot;I looked into this one personally.&lt;br&gt;&lt;br&gt;## Alert CS-789: Lateral Movement&lt;br&gt;Severity: Critical | Host: prod-web-03&lt;br&gt;Technique: T1021 (RDP)&lt;br&gt;&lt;br&gt;## Related Jira&lt;br&gt;SEC-1234 — Stalled 4 days. Janice is not happy.&lt;br&gt;SEC-1201 — Resolved, PR #456 didn&#39;t cover this.&lt;br&gt;&lt;br&gt;Recommendation: Escalate SEC-1234, create new&lt;br&gt;ticket for lateral movement. Want me to handle?&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;align=left;spacingLeft=10;" vertex="1" parent="ma-orch2">
          <mxGeometry x="350" y="35" width="320" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="e-ma-synth" edge="1" source="ma-think2" target="ma-final" parent="ma-orch2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connect Workers to Orch2 -->
        <mxCell id="e-ma-sec-back" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="ma-sec-result" target="ma-think2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-ma-proj-back" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="ma-proj-result" target="ma-think2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Back to user -->
        <mxCell id="ma-user-final" value="&lt;b&gt;User sees response&lt;/b&gt;&lt;br&gt;with security findings,&lt;br&gt;Jira status, and&lt;br&gt;actionable next steps" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="1120" width="230" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e-ma-final-user" style="strokeWidth=2;strokeColor=#82b366;" edge="1" source="ma-final" target="ma-user-final" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Parallel label -->
        <mxCell id="parallel-label" value="&lt;b&gt;Runs in parallel&lt;/b&gt;&lt;br&gt;via asyncio.gather()" style="text;html=1;align=center;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="395" width="150" height="40" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Playbook Execution Flow" id="playbook-flow">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="pb-title" value="&lt;b&gt;Responsibility (Playbook) Execution Flow&lt;/b&gt;" style="text;html=1;align=center;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="pb-user" value="&lt;b&gt;User:&lt;/b&gt; &quot;Run my morning brief&quot;" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="80" width="250" height="50" as="geometry"/>
        </mxCell>

        <!-- Path split -->
        <mxCell id="pb-split" value="Execution&lt;br&gt;mode?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="490" y="170" width="120" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="e-pb1" edge="1" source="pb-user" target="pb-split" parent="1" style="strokeWidth=2;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PATH A: SQS -->
        <mxCell id="pb-path-a" value="&lt;b&gt;Path A: SQS Trigger&lt;/b&gt;&lt;br&gt;(via trigger_responsibility tool)" style="swimlane;startSize=35;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="300" width="400" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a1" value="DB: Look up playbook&lt;br&gt;(fuzzy match by name)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pb-path-a">
          <mxGeometry x="30" y="50" width="180" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a-check" value="Active?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pb-path-a">
          <mxGeometry x="250" y="45" width="80" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a-inactive" value="&quot;Please activate&lt;br&gt;it first&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pb-path-a">
          <mxGeometry x="240" y="120" width="130" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a2" value="DB: INSERT INTO&lt;br&gt;playbook_executions&lt;br&gt;(status: pending)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pb-path-a">
          <mxGeometry x="30" y="120" width="170" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a3" value="SQS: Send message&lt;br&gt;{execution_id, playbook_id,&lt;br&gt;tenant_id}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="pb-path-a">
          <mxGeometry x="30" y="195" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="pb-a4" value="&lt;b&gt;Separate Playbook Engine&lt;/b&gt;&lt;br&gt;Polls SQS, processes&lt;br&gt;playbook nodes, stores&lt;br&gt;results in DB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="pb-path-a">
          <mxGeometry x="30" y="275" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="e-pba1" edge="1" source="pb-a1" target="pb-a-check" parent="pb-path-a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pba2" value="No" edge="1" source="pb-a-check" target="pb-a-inactive" parent="pb-path-a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pba3" value="Yes" edge="1" source="pb-a-check" target="pb-a2" parent="pb-path-a" style="edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="220" y="73"/>
              <mxPoint x="220" y="145"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="e-pba4" edge="1" source="pb-a2" target="pb-a3" parent="pb-path-a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pba5" edge="1" source="pb-a3" target="pb-a4" parent="pb-path-a">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- PATH B: In-process -->
        <mxCell id="pb-path-b" value="&lt;b&gt;Path B: In-Process Execution&lt;/b&gt;&lt;br&gt;(via /v1/responsibilities/execute)" style="swimlane;startSize=35;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="300" width="450" height="350" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b1" value="Match playbook +&lt;br&gt;load instructions from&lt;br&gt;RESPONSIBILITY_INSTRUCTIONS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="pb-path-b">
          <mxGeometry x="20" y="50" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b2" value="asyncio.create_task()&lt;br&gt;(background execution)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="pb-path-b">
          <mxGeometry x="20" y="125" width="200" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b3" value="&lt;b&gt;OrchestratorAgent&lt;/b&gt;&lt;br&gt;runs ReAct loop:&lt;br&gt;&lt;br&gt;Iter 1: fetch_emails +&lt;br&gt;fetch_calendar + list_alerts&lt;br&gt;+ search_jira + fetch_msgs&lt;br&gt;(ALL PARALLEL)&lt;br&gt;&lt;br&gt;Iter 2: synthesize response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" vertex="1" parent="pb-path-b">
          <mxGeometry x="20" y="190" width="220" height="145" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b-return" value="Return immediately:&lt;br&gt;{execution_id,&lt;br&gt;status: &quot;running&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pb-path-b">
          <mxGeometry x="280" y="125" width="150" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="pb-b-poll" value="Frontend polls:&lt;br&gt;GET /v1/responsibilities/&lt;br&gt;execution/{id}&lt;br&gt;&#8594; {status: completed,&lt;br&gt;   response: &quot;...&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="pb-path-b">
          <mxGeometry x="270" y="220" width="170" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e-pbb1" edge="1" source="pb-b1" target="pb-b2" parent="pb-path-b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pbb2" edge="1" source="pb-b2" target="pb-b3" parent="pb-path-b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pbb3" edge="1" source="pb-b2" target="pb-b-return" parent="pb-path-b">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pbb4" edge="1" source="pb-b-return" target="pb-b-poll" parent="pb-path-b" style="dashed=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connect split to paths -->
        <mxCell id="e-pb-a" value="Chat tool" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="pb-split" target="pb-a1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pb-b" value="API endpoint" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;" edge="1" source="pb-split" target="pb-b1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Post-execution -->
        <mxCell id="pb-post" value="&lt;b&gt;Post-Execution (both paths)&lt;/b&gt;&lt;br&gt;&lt;hr&gt;1. Store result in playbook_executions&lt;br&gt;2. Extract commitments &#8594; user_commitments&lt;br&gt;3. Extract reminders &#8594; user_reminders&lt;br&gt;4. Link via execution_context table&lt;br&gt;5. Available in next dashboard load + chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=0;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="700" width="300" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="e-pb-post1" style="dashed=1;" edge="1" source="pb-a4" target="pb-post" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-pb-post2" style="dashed=1;" edge="1" source="pb-b3" target="pb-post" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
