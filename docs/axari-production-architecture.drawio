        <!-- ==================== LEGEND ==================== -->
        <mxCell id="legend" value="&lt;b&gt;LEGEND&lt;/b&gt;" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#666666;rounded=1;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="80" width="350" height="180" as="geometry"/>
